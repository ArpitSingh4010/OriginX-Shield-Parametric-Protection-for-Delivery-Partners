# RakshaRide AI Service - Environment Variables
# ------------------------------------------------------------------------------
# Copy this file to .env for local/deployed AI service configuration.

# CORS allowed frontend URL(s). Comma-separated for multiple URLs.
# Examples: https://app.example.com,https://preview.example.vercel.app
FRONTEND_URL=https://raksha-ride.vercel.app

# AI Flask runtime
AI_SERVICE_PORT=5001
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_DEBUG=true
AI_SERVICE_PUBLIC_BASE_URL=http://localhost:5001

# Protect /retrain endpoint header X-Admin-Token
ADMIN_TOKEN=raksharide-admin
