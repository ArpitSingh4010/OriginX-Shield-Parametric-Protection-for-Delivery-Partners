# RakshaRide Frontend - Environment Variables
# ------------------------------------------------------------------------------
# Copy this file to .env and update values only when API/AI are hosted separately.
# For local development with Vite proxy and backend at /api, defaults can stay empty.

# Example (deployed backend): https://your-backend-host.com/api
VITE_API_BASE_URL=/api

# Example (deployed AI service): https://your-ai-host.com
# Keep /ai for local dev if using proxy.
VITE_AI_BASE_URL=/ai
