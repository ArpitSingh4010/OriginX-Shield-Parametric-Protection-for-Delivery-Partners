# RakshaRide Frontend - Environment Variables
# ------------------------------------------------------------------------------
# Copy this file to .env and update values only when API/AI are hosted separately.
# For local development with Vite proxy and backend at /api, the defaults can stay as-is.
# For deployed frontends, set absolute URLs, for example:
#   VITE_API_BASE_URL=https://api.example.com/api
#   VITE_AI_BASE_URL=https://ai.example.com

VITE_API_BASE_URL=/api

# Keep /ai for local dev if using proxy.
VITE_AI_BASE_URL=/ai
